# Production environment variables for AeroSync frontend
# When the app is built and deployed to Cloudflare, it will use these settings

# Backend API is served through Cloudflare tunnel at api.aerosync.live
VITE_API_URL=https://api.aerosync.live/api/

# In production the site will always be HTTPS via Cloudflare; no need
# for VITE_HTTPS here.
# Environment indicator
VITE_ENV=production
